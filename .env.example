# CodeCure Environment Variables
# For local development, copy to .env
# For Vercel deployment, set these in your project settings

# Flask Configuration
SECRET_KEY=your-secret-key-change-this

# MongoDB Configuration (Required for production)
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/codecure_db?retryWrites=true&w=majority
MONGO_DB_NAME=codecure_db

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here
