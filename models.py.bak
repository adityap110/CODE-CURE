import sqlite3
import os
from datetime import datetime, date
from config import Config

DB_PATH = Config.DB_PATH

def get_db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn

def init_db():
    conn = get_db()
    
    conn.execute('''CREATE TABLE IF NOT EXISTS users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        username TEXT UNIQUE NOT NULL,
        password_hash TEXT NOT NULL,
        role TEXT NOT NULL
    )''')
    
    conn.execute('''CREATE TABLE IF NOT EXISTS medicines (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT NOT NULL,
        category TEXT,
        quantity INTEGER NOT NULL,
        min_stock INTEGER NOT NULL,
        expiry_date TEXT,
        supplier TEXT,
        price REAL DEFAULT 0,
        created_at TEXT
    )''')

    conn.execute('''CREATE TABLE IF NOT EXISTS activity (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        action TEXT NOT NULL,
        detail TEXT NOT NULL,
        user TEXT NOT NULL,
        timestamp TEXT NOT NULL
    )''')
    
    conn.execute('''CREATE TABLE IF NOT EXISTS sales (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        invoice_id TEXT UNIQUE NOT NULL,
        customer_name TEXT,
        total_amount REAL,
        discount REAL DEFAULT 0,
        payment_method TEXT,
        sold_by TEXT,
        items_json TEXT,
        timestamp TEXT
    )''')

    # Seed demo medicines if empty
    if conn.execute("SELECT COUNT(*) FROM medicines").fetchone()[0] == 0:
        demo_medicines = [
            ("Paracetamol 500mg", "Analgesic", 150, 20, "2025-12-01", "MedCo", 2.50, datetime.utcnow().isoformat()),
            ("Amoxicillin 250mg", "Antibiotic", 8, 15, "2025-09-15", "PharmEx", 12.00, datetime.utcnow().isoformat()),
            ("Pantoprazole 40mg", "Antacid", 60, 10, "2026-03-20", "HealthPlus", 5.75, datetime.utcnow().isoformat()),
            ("Cetirizine 10mg", "Antihistamine", 3, 10, "2024-06-01", "MedCo", 3.00, datetime.utcnow().isoformat()),
            ("Metformin 500mg", "Antidiabetic", 200, 30, "2026-01-10", "DiaCare", 1.80, datetime.utcnow().isoformat()),
            ("Atorvastatin 10mg", "Statin", 45, 20, "2026-07-22", "CardioMed", 8.50, datetime.utcnow().isoformat()),
            ("Vitamin C 500mg", "Vitamin", 12, 25, "2025-11-30", "NutriLife", 4.00, datetime.utcnow().isoformat()),
            ("Ibuprofen 400mg", "Analgesic", 90, 15, "2026-02-14", "PharmEx", 3.25, datetime.utcnow().isoformat())
        ]
        conn.executemany(
            "INSERT INTO medicines (name,category,quantity,min_stock,expiry_date,supplier,price,created_at) VALUES (?,?,?,?,?,?,?,?)",
            demo_medicines
        )
        conn.commit()
        log_activity("System Init", "Demo data loaded", "system", conn)
        
    conn.close()


def log_activity(action, detail, user="system", conn=None):
    close_after = False
    if conn is None:
        conn = get_db()
        close_after = True
    conn.execute(
        "INSERT INTO activity (action, detail, user, timestamp) VALUES (?, ?, ?, ?)",
        (action, detail, user, datetime.utcnow().isoformat())
    )
    if close_after:
        conn.commit()
        conn.close()


def record_sale(invoice_id, total, items_json, sold_by, customer="Walk-in", payment="Cash", discount=0):
    conn = get_db()
    conn.execute(
        "INSERT INTO sales (invoice_id, customer_name, total_amount, discount, payment_method, sold_by, items_json, timestamp) VALUES (?,?,?,?,?,?,?,?)",
        (invoice_id, customer, total, discount, payment, sold_by, items_json, datetime.utcnow().isoformat())
    )
    conn.commit()
    conn.close()
